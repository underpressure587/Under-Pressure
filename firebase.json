{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "deploy.sh",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "index.html",
        "headers": [{
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }]
      },
      {
        "source": "**/*.js",
        "headers": [{
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }]
      },
      {
        "source": "**/*.css",
        "headers": [{
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
